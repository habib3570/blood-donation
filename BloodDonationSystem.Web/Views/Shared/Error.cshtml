@{
    ViewData["Title"] = "Error";
}

<section class="section-pad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div style="font-size:5rem;margin-bottom:1rem;">😕</div>
                <div style="font-size:2rem;font-weight:800;color:var(--deep-red);margin-bottom:0.5rem;">
                    Oops! Something went wrong
                </div>
                <div style="font-size:0.9rem;color:var(--text-muted);margin-bottom:2rem;line-height:1.7;">
                    We're sorry, but something went wrong on our end.
                    Please try again or go back to the home page.
                </div>
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-controller="Home" asp-action="Index" class="btn-red">
                        <i class="fas fa-home"></i> Go Home
                    </a>
                    <button onclick="history.back()" class="btn-outline-red">
                        <i class="fas fa-arrow-left"></i> Go Back
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>