@model BloodDonationSystem.Application.DTOs.User.UpdateProfileDto
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="page-header">
    <div class="container">
        <div class="page-header-title">👤 My Profile</div>
        <div class="page-header-sub">Manage your personal information</div>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        <div class="row g-4">

            <!-- LEFT: Profile Summary -->
            <div class="col-lg-4">
                <div class="form-card text-center mb-3">
                    <div class="donor-avatar"
                         style="width:80px;height:80px;font-size:2rem;margin:0 auto 1rem;">
                        @User.Identity?.Name?[0]
                    </div>
                    <div style="font-size:1.1rem;font-weight:800;color:var(--navy-blue);">
                        @User.Identity?.Name
                    </div>
                    <div style="font-size:0.82rem;color:var(--text-muted);margin-top:0.25rem;">
                        @User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                    </div>

                    <!-- Profile Completion -->
                    <div class="mt-3">
                        <div style="font-size:0.78rem;font-weight:600;color:var(--navy-blue);
                                    margin-bottom:0.4rem;display:flex;justify-content:space-between;">
                            <span>Profile Complete</span>
                            <span style="color:var(--deep-red);">85%</span>
                        </div>
                        <div style="background:var(--card-border);border-radius:10px;
                                    height:8px;overflow:hidden;">
                            <div style="background:var(--deep-red);border-radius:10px;
                                        height:100%;width:85%;"></div>
                        </div>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="info-card mb-3">
                    <div class="info-card-title"><i class="fas fa-link"></i> Account</div>
                    <div class="d-flex flex-column gap-2 mt-2">
                        <a asp-action="ChangePassword" class="btn-sm-outline justify-content-start">
                            <i class="fas fa-lock"></i> Change Password
                        </a>
                        <a asp-action="LoginActivity" class="btn-sm-outline justify-content-start">
                            <i class="fas fa-shield-alt"></i> Login Activity
                        </a>
                        <a asp-controller="Statistics" asp-action="Index"
                           class="btn-sm-outline justify-content-start">
                            <i class="fas fa-chart-bar"></i> My Statistics
                        </a>
                    </div>
                </div>

                <!-- Notification Preferences -->
                <div class="info-card">
                    <div class="info-card-title">
                        <i class="fas fa-bell"></i> Notification Preferences
                    </div>
                    <div class="d-flex flex-column gap-2 mt-2">
                        @foreach (var pref in new[]
                                                {
                                                "Email Notifications",
                                                "SMS Notifications",
                                                "Emergency Alerts",
                                                "Donation Reminders"
                                                })
                        {
                            <label class="d-flex align-items-center justify-content-between"
                                   style="cursor:pointer;font-size:0.82rem;color:var(--navy-blue);">
                                <span>@pref</span>
                                <div style="width:36px;height:20px;background:var(--deep-red);
                                                border-radius:20px;position:relative;cursor:pointer;">
                                    <div style="width:16px;height:16px;background:white;
                                                    border-radius:50%;position:absolute;
                                                    top:2px;right:2px;transition:all 0.2s;"></div>
                                </div>
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- RIGHT: Edit Form -->
            <div class="col-lg-8">
                <div class="form-card">
                    <div class="form-card-title">Edit Profile Information</div>
                    <div class="form-card-subtitle">Update your personal details below</div>

                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="validation-msg mb-3"></div>

                        <div class="row g-3">

                            <div class="col-12">
                                <div style="font-size:0.82rem;font-weight:700;color:var(--navy-blue);
                                            padding:0.6rem 0.9rem;background:var(--light-gray);
                                            border-radius:8px;margin-bottom:0.5rem;">
                                    👤 Personal Information
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">Full Name *</label>
                                <div class="input-group-custom">
                                    <i class="fas fa-user input-icon"></i>
                                    <input asp-for="FullName"
                                           class="form-control-custom input-with-icon"
                                           placeholder="Your full name" />
                                </div>
                                <span asp-validation-for="FullName" class="validation-msg"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">Phone Number</label>
                                <div class="input-group-custom">
                                    <i class="fas fa-phone input-icon"></i>
                                    <input asp-for="PhoneNumber"
                                           class="form-control-custom input-with-icon"
                                           placeholder="01XXXXXXXXX" />
                                </div>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label-custom">Blood Group *</label>
                                <select asp-for="BloodGroup" class="form-select-custom">
                                    <option value="0">A+</option>
                                    <option value="1">A-</option>
                                    <option value="2">B+</option>
                                    <option value="3">B-</option>
                                    <option value="4">AB+</option>
                                    <option value="5">AB-</option>
                                    <option value="6">O+</option>
                                    <option value="7">O-</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label-custom">Gender *</label>
                                <select asp-for="Gender" class="form-select-custom">
                                    <option value="0">Male</option>
                                    <option value="1">Female</option>
                                    <option value="2">Other</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label-custom">Date of Birth *</label>
                                <input asp-for="DateOfBirth"
                                       type="date"
                                       class="form-control-custom" />
                            </div>

                            <div class="col-12">
                                <div style="font-size:0.82rem;font-weight:700;color:var(--navy-blue);
                                            padding:0.6rem 0.9rem;background:var(--light-gray);
                                            border-radius:8px;margin-bottom:0.5rem;margin-top:0.5rem;">
                                    📍 Location
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">District *</label>
                                <select asp-for="District" class="form-select-custom">
                                    @foreach (var d in new[] {
                                                                        "Dhaka","Chittagong","Sylhet","Rajshahi",
                                                                        "Khulna","Barisal","Rangpur","Mymensingh",
                                                                        "Comilla","Narayanganj"
                                                                        })
                                    {
                                        <option>@d</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">Upazila *</label>
                                <input asp-for="Upazila"
                                       class="form-control-custom"
                                       placeholder="Your upazila" />
                            </div>

                            <div class="col-12">
                                <label class="form-label-custom">Full Address</label>
                                <input asp-for="Address"
                                       class="form-control-custom"
                                       placeholder="House, Road, Area" />
                            </div>

                            <div class="col-12">
                                <div class="info-card">
                                    <div class="info-card-title">
                                        <i class="fas fa-map-marker-alt"></i>
                                        GPS Location (for nearby donor search)
                                    </div>
                                    <div class="d-flex gap-2 align-items-center flex-wrap mt-2">
                                        <input asp-for="Latitude"
                                               id="profLat"
                                               class="form-control-custom"
                                               style="max-width:180px;"
                                               placeholder="Latitude" readonly />
                                        <input asp-for="Longitude"
                                               id="profLng"
                                               class="form-control-custom"
                                               style="max-width:180px;"
                                               placeholder="Longitude" readonly />
                                        <button type="button"
                                                class="btn-sm-outline"
                                                onclick="getCurrentLocation('profLat','profLng', () => showToast('Location updated!', 'success'))">
                                            <i class="fas fa-location-arrow"></i> Detect
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Profile Image -->
                            <div class="col-12">
                                <label class="form-label-custom">Profile Photo</label>
                                <div class="info-card">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="donor-avatar"
                                             style="width:52px;height:52px;font-size:1.3rem;">
                                            @User.Identity?.Name?[0]
                                        </div>
                                        <div>
                                            <input type="file"
                                                   name="ProfileImage"
                                                   accept="image/*"
                                                   class="form-control-custom"
                                                   style="font-size:0.8rem;" />
                                            <div style="font-size:0.72rem;color:var(--text-muted);
                                                        margin-top:0.3rem;">
                                                JPG, PNG, max 2MB
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="d-flex gap-3">
                                    <a asp-controller="Home" asp-action="Index"
                                       class="btn-outline-red">
                                        <i class="fas fa-times"></i> Cancel
                                    </a>
                                    <button type="submit"
                                            class="btn-red flex-grow-1 justify-content-center">
                                        <i class="fas fa-save"></i> Save Changes
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}