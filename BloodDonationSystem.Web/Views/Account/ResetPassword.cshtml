@model BloodDonationSystem.Application.DTOs.Auth.ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
}

<div class="page-header">
    <div class="container">
        <div class="page-header-title">🔐 Reset Password</div>
        <div class="page-header-sub">Create a new password for your account</div>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="form-card">
                    <div class="text-center mb-4">
                        <div style="font-size:2.5rem;">🔐</div>
                        <div class="form-card-title">Set New Password</div>
                        <div class="form-card-subtitle">
                            Choose a strong password for your account
                        </div>
                    </div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Token" />
                        <div asp-validation-summary="All" class="validation-msg mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label-custom">New Password</label>
                            <div class="input-group-custom">
                                <i class="fas fa-lock input-icon"></i>
                                <input asp-for="NewPassword" type="password"
                                       class="form-control-custom input-with-icon"
                                       placeholder="Minimum 6 characters" />
                            </div>
                            <span asp-validation-for="NewPassword" class="validation-msg"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label-custom">Confirm New Password</label>
                            <div class="input-group-custom">
                                <i class="fas fa-lock input-icon"></i>
                                <input asp-for="ConfirmPassword" type="password"
                                       class="form-control-custom input-with-icon"
                                       placeholder="Re-enter password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="validation-msg"></span>
                        </div>

                        <button type="submit" class="btn-red w-100 justify-content-center"
                                style="padding:0.8rem;">
                            <i class="fas fa-check"></i> Reset Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}