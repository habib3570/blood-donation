@model BloodDonationSystem.Application.DTOs.Auth.ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="page-header">
    <div class="container">
        <div class="page-header-title">🔑 Forgot Password</div>
        <div class="page-header-sub">We'll send you a reset link</div>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="form-card">
                    <div class="text-center mb-4">
                        <div style="font-size:2.5rem;">🔑</div>
                        <div class="form-card-title">Reset Password</div>
                        <div class="form-card-subtitle">
                            Enter your email and we'll send you a reset link
                        </div>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="validation-msg mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label-custom">Email Address</label>
                            <div class="input-group-custom">
                                <i class="fas fa-envelope input-icon"></i>
                                <input asp-for="Email"
                                       class="form-control-custom input-with-icon"
                                       placeholder="your@email.com" />
                            </div>
                            <span asp-validation-for="Email" class="validation-msg"></span>
                        </div>

                        <button type="submit" class="btn-red w-100 justify-content-center"
                                style="padding:0.8rem;">
                            <i class="fas fa-paper-plane"></i> Send Reset Link
                        </button>
                    </form>

                    <div class="text-center mt-4" style="font-size:0.875rem;color:var(--text-muted);">
                        Remember your password?
                        <a asp-action="Login" style="color:var(--deep-red);font-weight:700;
                                                      text-decoration:none;">Sign In</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}