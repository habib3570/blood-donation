@using BloodDonationSystem.Application.DTOs.BloodBank
@model List<BloodBankDto>
@{
    ViewData["Title"] = "Blood Banks";
}

<div class="page-header">
    <div class="container">
        <div class="page-header-title">🩸 Blood Banks</div>
        <div class="page-header-sub">Check blood stock availability across the city</div>
    </div>
</div>

<section class="section-pad">
    <div class="container">

        @{
            var lowStocks = ViewBag.LowStocks as List<BloodStockDto> ?? new();
        }
        @if (lowStocks.Any())
        {
            <div class="info-card mb-4"
                 style="background:#FEF2F2;border:2px solid #FECACA;">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-exclamation-triangle text-red"></i>
                    <span style="font-weight:700;color:var(--deep-red);">
                        Low Stock Alert: @lowStocks.Count blood group(s) running low
                    </span>
                </div>
            </div>
        }

        <div class="row g-3">
            @foreach (var bank in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="donor-card h-100">
                        <div class="donor-card-header">
                            <div style="width:48px;height:48px;border-radius:12px;
                                            background:var(--deep-red);color:white;
                                            display:flex;align-items:center;
                                            justify-content:center;font-size:1.2rem;
                                            flex-shrink:0;">
                                <i class="fas fa-vial"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="donor-name">@bank.Name</div>
                                <div class="donor-loc">
                                    <i class="fas fa-map-marker-alt"></i>
                                    @bank.Upazila, @bank.District
                                </div>
                            </div>
                        </div>
                        <div class="donor-card-body">
                            <div style="font-size:0.78rem;font-weight:600;
                                            color:var(--navy-blue);margin-bottom:0.5rem;">
                                Stock Availability
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var stock in bank.Stocks.Take(8))
                                {
                                    <div style="background:@(stock.IsLow ? "#FEF2F2" : "var(--light-gray)");
                                                        border:1px solid @(stock.IsLow ? "#FECACA" : "var(--card-border)");
                                                        border-radius:8px;padding:0.35rem 0.6rem;
                                                        text-align:center;min-width:50px;">
                                        <div style="font-size:0.78rem;font-weight:800;
                                                            color:@(stock.IsLow ? "var(--deep-red)" : "var(--navy-blue)");">
                                            @stock.BloodGroupDisplay
                                        </div>
                                        <div style="font-size:0.65rem;color:var(--text-muted);">
                                            @stock.UnitsAvailable units
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="donor-card-footer">
                            <a asp-action="Details" asp-route-id="@bank.Id"
                               class="btn-sm-outline flex-grow-1 justify-content-center">
                                <i class="fas fa-info-circle"></i> View Details
                            </a>
                            @if (!string.IsNullOrEmpty(bank.PhoneNumber))
                            {
                                <a href="tel:@bank.PhoneNumber" class="btn-sm-red">
                                    <i class="fas fa-phone"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="info-card text-center py-5">
                <div style="font-size:3rem;margin-bottom:1rem;">🩸</div>
                <div style="font-size:1.1rem;font-weight:700;color:var(--navy-blue);">
                    No Blood Banks Found
                </div>
            </div>
        }
    </div>
</section>