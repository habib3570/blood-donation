@using BloodDonationSystem.Application.DTOs
@model List<SuccessStoryDto>
@{
    ViewData["Title"] = "Success Stories";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="page-header-title">❤️ Success Stories</div>
                <div class="page-header-sub">Real stories from our community</div>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="Create" class="btn-red">
                    <i class="fas fa-pen"></i> Share Your Story
                </a>
            }
        </div>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        @if (Model != null && Model.Any())
        {
            <div class="row g-4">
                @foreach (var story in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="donor-card h-100">
                            @if (!string.IsNullOrEmpty(story.ImageUrl))
                            {
                                <img src="@story.ImageUrl"
                                     alt="@story.Title"
                                     style="width:100%;height:180px;object-fit:cover;" />
                            }
                            else
                            {
                                <div style="height:120px;background:linear-gradient(135deg,
                                                        var(--deep-red-light),white);
                                                        display:flex;align-items:center;
                                                        justify-content:center;font-size:3rem;">
                                    ❤️
                                </div>
                            }

                            <div class="donor-card-body">
                                <div style="font-size:1rem;font-weight:800;
                                                    color:var(--navy-blue);margin-bottom:0.5rem;
                                                    line-height:1.3;">
                                    @story.Title
                                </div>
                                <div style="font-size:0.82rem;color:var(--text-muted);
                                                    line-height:1.6;display:-webkit-box;
                                                    -webkit-line-clamp:3;-webkit-box-orient:vertical;
                                                    overflow:hidden;">
                                    @story.Content
                                </div>
                            </div>

                            <div class="donor-card-footer justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar-sm" style="flex-shrink:0;">
                                        @story.AuthorName[0]
                                    </div>
                                    <div>
                                        <div style="font-size:0.8rem;font-weight:600;
                                                            color:var(--navy-blue);">
                                            @story.AuthorName
                                        </div>
                                        <div style="font-size:0.7rem;color:var(--text-muted);">
                                            @story.CreatedAt.ToString("dd MMM yyyy")
                                        </div>
                                    </div>
                                </div>
                                <div style="font-size:0.72rem;color:var(--text-muted);">
                                    <i class="fas fa-eye"></i> @story.ViewCount views
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="info-card text-center py-5">
                <div style="font-size:3rem;margin-bottom:1rem;">❤️</div>
                <div style="font-size:1.1rem;font-weight:700;color:var(--navy-blue);
                                margin-bottom:0.5rem;">
                    No Stories Yet
                </div>
                <div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:1.5rem;">
                    Be the first to share your blood donation story!
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="Create" class="btn-red">
                        <i class="fas fa-pen"></i> Share Your Story
                    </a>
                }
            </div>
        }
    </div>
</section>