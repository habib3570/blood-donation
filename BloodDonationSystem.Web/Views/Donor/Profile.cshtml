@using BloodDonationSystem.Application.DTOs.Donor
@model DonorDto
@{
    ViewData["Title"] = $"{Model.FullName} - Donor Profile";
}

<div class="page-header">
    <div class="container">
        <div class="breadcrumb-custom">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="breadcrumb-sep">/</span>
            <a asp-controller="Donor" asp-action="Search">Donors</a>
            <span class="breadcrumb-sep">/</span>
            <span>@Model.FullName</span>
        </div>
    </div>
</div>

<section class="section-pad">
    <div class="container">
        <div class="row g-4">

            <!-- LEFT: Profile Card -->
            <div class="col-lg-4">

                <!-- Main Card -->
                <div class="form-card text-center mb-3">
                    <div class="donor-avatar"
                         style="width:80px;height:80px;font-size:2rem;margin:0 auto 1rem;">
                        @Model.FullName[0]
                    </div>
                    <div style="font-size:1.2rem;font-weight:800;color:var(--navy-blue);">
                        @Model.FullName
                        @if (Model.IsVerifiedDonor)
                        {
                            <i class="fas fa-check-circle"
                               style="color:var(--success-green);font-size:1rem;"></i>
                        }
                    </div>
                    <div style="font-size:0.85rem;color:var(--text-muted);margin-top:0.25rem;">
                        <i class="fas fa-map-marker-alt"></i> @Model.Upazila, @Model.District
                    </div>

                    <!-- Blood Badge -->
                    <div style="margin:1rem 0;">
                        <span class="donor-blood-tag"
                              style="position:static;font-size:1.3rem;padding:0.4rem 1.25rem;">
                            🩸 @Model.BloodGroupDisplay
                        </span>
                    </div>

                    <!-- Level -->
                    @{
                        var lc = Model.Level.ToString() switch
                        {
                            "LifeSaver" => "lv-gold",
                            "Hero" => "lv-hero",
                            "Helper" => "lv-silver",
                            _ => "lv-new"
                        };
                        var le = Model.Level.ToString() switch
                        {
                            "LifeSaver" => "🏆",
                            "Hero" => "⚡",
                            "Helper" => "🥈",
                            _ => "🆕"
                        };
                    }
                    <span class="level-badge @lc"
                          style="font-size:0.85rem;padding:0.35rem 0.85rem;">
                        @le @Model.LevelDisplay
                    </span>

                    <!-- Availability -->
                    <div class="mt-3">
                        <span class="avail-badge @(Model.IsAvailable ? "avail-yes" : "avail-no")"
                              style="font-size:0.85rem;padding:0.4rem 1rem;">
                            <span class="avail-dot"></span>
                            @(Model.IsAvailable ? "Available to Donate" : "Currently Unavailable")
                        </span>
                    </div>

                    @if (Model.LastSeenAt.HasValue)
                    {
                        <div class="mt-2" style="font-size:0.75rem;color:var(--text-muted);">
                            Last seen @((DateTime.UtcNow - Model.LastSeenAt.Value).TotalMinutes < 60
                                                    ? $"{(int)(DateTime.UtcNow - Model.LastSeenAt.Value).TotalMinutes}m ago"
                                                    : $"{(int)(DateTime.UtcNow - Model.LastSeenAt.Value).TotalHours}h ago")
                    </div>
                                        }

                    <!-- Action Buttons -->
                    @if (User.Identity?.IsAuthenticated == true && Model.IsAvailable)
                    {
                        <div class="d-flex gap-2 mt-4">
                            <a href="tel:@Model.PhoneNumber" class="btn-red flex-grow-1 justify-content-center">
                                <i class="fas fa-phone"></i> Call
                            </a>
                            <a href="https://wa.me/@Model.PhoneNumber"
                               target="_blank" class="btn-sm-outline"
                               style="padding:0.5rem 1rem;">
                                <i class="fab fa-whatsapp fa-lg"></i>
                            </a>
                            <a asp-controller="Chat" asp-action="Index"
                               asp-route-userId="@Model.UserId"
                               class="btn-sm-outline" style="padding:0.5rem 1rem;">
                                <i class="fas fa-comment fa-lg"></i>
                            </a>
                        </div>

                        <button class="btn-sm-outline w-100 justify-content-center mt-2"
                                data-fav="@(ViewBag.IsFavorite?.ToString()?.ToLower() ?? "false")"
                                onclick="toggleFavorite(@Model.DonorProfileId, this)"
                                id="favBtn">
                            @if (ViewBag.IsFavorite == true)
                            {
                                <i class="fas fa-heart" style="color:var(--deep-red);"></i>
                                <span>Remove from Favorites</span>
                            }
                            else
                            {
                                <i class="far fa-heart"></i>
                                <span>Add to Favorites</span>
                            }
                        </button>
                    }
                </div>

                <!-- Stats Card -->
                <div class="info-card mb-3">
                    <div class="info-card-title"><i class="fas fa-chart-bar"></i> Donor Stats</div>
                    <div class="row g-2 mt-1">
                        <div class="col-6">
                            <div style="text-align:center;background:white;border-radius:10px;padding:0.75rem;">
                                <div style="font-size:1.3rem;font-weight:800;color:var(--deep-red);">
                                    @Model.TotalDonations
                                </div>
                                <div style="font-size:0.72rem;color:var(--text-muted);">Donations</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="text-align:center;background:white;border-radius:10px;padding:0.75rem;">
                                <div style="font-size:1.3rem;font-weight:800;color:var(--navy-blue);">
                                    @Model.AverageRating.ToString("0.0") ⭐
                                </div>
                                <div style="font-size:0.72rem;color:var(--text-muted);">Rating</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="text-align:center;background:white;border-radius:10px;padding:0.75rem;">
                                <div style="font-size:1.3rem;font-weight:800;color:var(--success-green);">
                                    @Model.LivesSaved
                                </div>
                                <div style="font-size:0.72rem;color:var(--text-muted);">Lives Saved</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div style="text-align:center;background:white;border-radius:10px;padding:0.75rem;">
                                <div style="font-size:1.3rem;font-weight:800;color:var(--warning-orange);">
                                    @Model.TotalPoints
                                </div>
                                <div style="font-size:0.72rem;color:var(--text-muted);">Points</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Eligibility -->
                @if (Model.NextEligibleDate.HasValue)
                {
                    <div class="info-card">
                        <div class="info-card-title">
                            <i class="fas fa-calendar-check"></i> Next Eligible Date
                        </div>
                        @{
                            var isEligible = Model.NextEligibleDate.Value <= DateTime.UtcNow;
                            var daysLeft = (Model.NextEligibleDate.Value - DateTime.UtcNow).Days;
                        }
                        @if (isEligible)
                        {
                            <div class="avail-badge avail-yes mt-2">
                                <span class="avail-dot"></span> Eligible to donate now!
                            </div>
                        }
                        else
                        {
                            <div style="font-size:0.875rem;color:var(--navy-blue);margin-top:0.5rem;">
                                <strong style="color:var(--deep-red);">@daysLeft days</strong>
                                until next donation
                            </div>
                            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.25rem;">
                                @Model.NextEligibleDate.Value.ToString("dd MMMM yyyy")
                            </div>
                            <!-- Progress Bar -->
                            <div style="background:var(--card-border);border-radius:10px;
                                                height:6px;margin-top:0.75rem;overflow:hidden;">
                                <div style="background:var(--deep-red);border-radius:10px;height:100%;
                                                    width:@(Math.Max(0, Math.Min(100, (90 - daysLeft) * 100 / 90)))%;
                                                    transition:width 0.5s;">
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- RIGHT: Details -->
            <div class="col-lg-8">

                <!-- Donation History Timeline -->
                <div class="form-card mb-4">
                    <div style="font-size:1rem;font-weight:700;color:var(--navy-blue);margin-bottom:1.25rem;
                                display:flex;align-items:center;gap:0.5rem;">
                        <i class="fas fa-history" style="color:var(--deep-red);"></i>
                        Donation History
                    </div>

                    @{
                        var history = ViewBag.History as
                        List<BloodDonationSystem.Application.DTOs.Donation.DonationHistoryDto>
                        ?? new();
                    }

                    @if (history.Any())
                    {
                        <div style="position:relative;padding-left:1.5rem;">
                            <div style="position:absolute;left:7px;top:0;bottom:0;
                                            width:2px;background:var(--card-border);"></div>

                            @foreach (var donation in history)
                            {
                                <div style="position:relative;margin-bottom:1.25rem;">
                                    <div style="position:absolute;left:-1.5rem;top:2px;
                                                        width:14px;height:14px;border-radius:50%;
                                                        background:var(--deep-red);
                                                        border:2px solid white;
                                                        box-shadow:0 0 0 2px var(--deep-red);"></div>
                                    <div class="info-card" style="margin-left:0.5rem;">
                                        <div class="d-flex align-items-start justify-content-between gap-2">
                                            <div>
                                                <div style="font-weight:700;font-size:0.875rem;
                                                                    color:var(--navy-blue);">
                                                    @donation.HospitalName
                                                    @if (donation.IsEmergency)
                                                    {
                                                        <span class="status-pill sp-rejected"
                                                              style="font-size:0.65rem;margin-left:0.3rem;">
                                                            <i class="fas fa-bolt"></i> Emergency
                                                        </span>
                                                    }
                                                </div>
                                                <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.2rem;">
                                                    <i class="fas fa-map-marker-alt"></i> @donation.District
                                                </div>
                                                @if (!string.IsNullOrEmpty(donation.RecipientName))
                                                {
                                                    <div style="font-size:0.78rem;color:var(--text-muted);">
                                                        <i class="fas fa-user"></i> @donation.RecipientName
                                                    </div>
                                                }
                                            </div>
                                            <div class="text-end" style="flex-shrink:0;">
                                                <div style="font-size:0.82rem;font-weight:600;
                                                                    color:var(--navy-blue);">
                                                    @donation.DonationDate.ToString("dd MMM yyyy")
                                                </div>
                                                @if (donation.CertificateGenerated)
                                                {
                                                    <a asp-controller="Certificate"
                                                       asp-action="Download"
                                                       asp-route-donationId="@donation.Id"
                                                       class="btn-sm-outline mt-1"
                                                       style="font-size:0.7rem;">
                                                        <i class="fas fa-certificate"></i> Cert
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3"
                             style="color:var(--text-muted);font-size:0.85rem;">
                            No donation history yet
                        </div>
                    }
                </div>

                <!-- Ratings -->
                <div class="form-card">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div style="font-size:1rem;font-weight:700;color:var(--navy-blue);
                                    display:flex;align-items:center;gap:0.5rem;">
                            <i class="fas fa-star" style="color:var(--warning-orange);"></i>
                            Reviews & Ratings
                            <span style="font-size:0.78rem;color:var(--text-muted);font-weight:400;">
                                (@Model.TotalRatings reviews)
                            </span>
                        </div>
                        <div style="font-size:1.3rem;font-weight:800;color:var(--navy-blue);">
                            @Model.AverageRating.ToString("0.0")
                            <span style="color:#F59E0B;">⭐</span>
                        </div>
                    </div>

                    @{
                        var ratings = ViewBag.Ratings as
                        List<BloodDonationSystem.Application.DTOs.Rating.RatingDto>
                        ?? new();
                    }

                    @if (ratings.Any())
                    {
                        @foreach (var rating in ratings)
                        {
                            <div class="info-card mb-2">
                                <div class="d-flex align-items-start gap-2">
                                    <div class="user-avatar-sm" style="flex-shrink:0;">
                                        @rating.RaterName[0]
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center justify-content-between">
                                            <div style="font-weight:600;font-size:0.85rem;
                                                                color:var(--navy-blue);">
                                                @rating.RaterName
                                                @if (rating.IsThankYouMessage)
                                                {
                                                    <span class="badge-verified">❤️ Thank You</span>
                                                }
                                            </div>
                                            <div style="color:#F59E0B;font-size:0.82rem;">
                                                @for (int i = 0; i < rating.Stars; i++)
                                                {
                                                    <i class="fas fa-star"></i>
                                                }
                                                @for (int i = rating.Stars; i < 5; i++)
                                                {
                                                    <i class="far fa-star"
                                                       style="color:var(--card-border);"></i>
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(rating.Comment))
                                        {
                                            <div style="font-size:0.82rem;color:var(--text-muted);
                                                                    margin-top:0.35rem;line-height:1.5;">
                                                "@rating.Comment"
                                            </div>
                                        }
                                        <div style="font-size:0.72rem;color:var(--text-muted);
                                                            margin-top:0.3rem;">
                                            @rating.CreatedAt.ToString("dd MMM yyyy")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-3"
                             style="color:var(--text-muted);font-size:0.85rem;">
                            No reviews yet. Be the first to review!
                        </div>
                    }

                    <!-- Rate Form -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="mt-3 pt-3"
                             style="border-top:1px solid var(--card-border);">
                            <div style="font-weight:600;font-size:0.875rem;
                                            color:var(--navy-blue);margin-bottom:0.75rem;">
                                Rate this donor
                            </div>
                            <form asp-controller="Rating" asp-action="Rate"
                                  asp-route-donorProfileId="@Model.DonorProfileId"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <div class="d-flex gap-2 mb-2" id="starRating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="far fa-star"
                                           style="font-size:1.3rem;color:#F59E0B;cursor:pointer;"
                                           data-star="@i"
                                           onclick="setRating(@i)"></i>
                                    }
                                </div>
                                <input type="hidden" name="Stars" id="starsInput" value="0" />
                                <textarea name="Comment"
                                      class="form-control-custom mb-2"
                                      rows="2"
                                      placeholder="Write a review (optional)..."></textarea>
                                <button type="submit" class="btn-sm-red"
                                        style="padding:0.5rem 1.25rem;">
                                    <i class="fas fa-star"></i> Submit Review
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function setRating(stars) {
            document.getElementById('starsInput').value = stars;
            document.querySelectorAll('#starRating i').forEach((star, i) => {
                star.className = i < stars ? 'fas fa-star' : 'far fa-star';
                star.style.color = '#F59E0B';
            });
        }
    </script>
}