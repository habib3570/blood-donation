@using BloodDonationSystem.Application.DTOs.BloodRequest
@model List<BloodRequestDto>
@{
    ViewData["Title"] = "Manage Requests";
    Layout = "~/Views/Shared/_Layout.Admin.cshtml";
}

<div class="admin-page-header">
    <div class="admin-page-title">🩸 Manage Blood Requests</div>
    <div class="admin-page-sub">Monitor all active blood requests</div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <span>All Requests</span>
        <span style="font-size:0.75rem;color:var(--text-muted);">
            @(Model?.Count ?? 0) records
        </span>
    </div>
    <div class="admin-card-body" style="padding:0;">
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Blood</th>
                        <th>Hospital</th>
                        <th>Requester</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        @foreach (var req in Model)
                        {
                            <tr>
                                <td>@req.PatientName</td>
                                <td>
                                    <span class="donor-blood-tag"
                                          style="position:static;font-size:0.78rem;">
                                        @req.BloodGroupDisplay
                                    </span>
                                </td>
                                <td style="font-size:0.82rem;">@req.HospitalName</td>
                                <td style="font-size:0.82rem;">@req.RequesterName</td>
                                <td>
                                    @{
                                        var sc = req.Status.ToString() switch
                                        {
                                            "Pending" => "sp-pending",
                                            "Accepted" => "sp-accepted",
                                            "Completed" => "sp-completed",
                                            "Rejected" => "sp-rejected",
                                            _ => "sp-expired"
                                        };
                                    }
                                    <span class="status-pill @sc">@req.StatusDisplay</span>
                                </td>
                                <td style="font-size:0.78rem;color:var(--text-muted);">
                                    @req.CreatedAt.ToString("dd MMM yy")
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@req.Id"
                                       class="btn-sm-outline">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>