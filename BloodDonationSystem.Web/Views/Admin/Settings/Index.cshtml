@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_Layout.Admin.cshtml";
}

<div class="admin-page-header">
    <div class="admin-page-title">⚙️ System Settings</div>
    <div class="admin-page-sub">Configure application settings</div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="admin-card">
            <div class="admin-card-header"><span>General Settings</span></div>
            <div class="admin-card-body">
                <div class="mb-3">
                    <label class="form-label-custom">Max Emergency Requests/Day</label>
                    <input type="number" class="form-control-custom" value="3" />
                </div>
                <div class="mb-3">
                    <label class="form-label-custom">Min Days Between Donations</label>
                    <input type="number" class="form-control-custom" value="90" />
                </div>
                <div class="mb-3">
                    <label class="form-label-custom">Request Expiry (Hours)</label>
                    <input type="number" class="form-control-custom" value="6" />
                </div>
                <button class="btn-red"><i class="fas fa-save"></i> Save Settings</button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="admin-card">
            <div class="admin-card-header"><span>Background Jobs</span></div>
            <div class="admin-card-body">
                <div class="d-flex flex-column gap-2">
                    <a href="/admin/hangfire" target="_blank" class="btn-sm-outline justify-content-start">
                        <i class="fas fa-tasks"></i> Open Hangfire Dashboard
                    </a>
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted);margin-top:1rem;">
                    Active recurring jobs: Donation Reminder, Birthday Wish,
                    Request Expiry, Blood Stock Warning, Monthly Top Donor
                </div>
            </div>
        </div>
    </div>
</div>