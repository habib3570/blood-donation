@using BloodDonationSystem.Application.DTOs.User
@model UserProfileDto
@{
    ViewData["Title"] = "User Details";
    Layout = "_Layout.Admin";
}

<div class="admin-page-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <div class="admin-page-title">👤 User Details</div>
            <div class="admin-page-sub">Complete profile information</div>
        </div>
        <a asp-controller="AdminUser" asp-action="Index" class="btn-sm-outline">
            <i class="fas fa-arrow-left"></i> Back to Users
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="admin-card">
            <div class="admin-card-body text-center">
                <div class="donor-avatar" style="width:80px;height:80px;font-size:2rem;margin:0 auto 1rem;">
                    @Model.FullName[0]
                </div>
                <div style="font-size:1.2rem;font-weight:800;color:var(--navy-blue);">
                    @Model.FullName
                </div>
                <div style="font-size:0.85rem;color:var(--text-muted);margin-top:0.25rem;">
                    @Model.Email
                </div>

                <span class="donor-blood-tag" style="position:static;font-size:1.1rem;padding:0.4rem 1rem;margin-top:1rem;display:inline-block;">
                    🩸 @Model.BloodGroupDisplay
                </span>

                <div class="mt-3 d-flex flex-column gap-2">
                    @if (Model.IsBlocked)
                    {
                        <span class="status-pill sp-rejected">Blocked</span>
                        <button onclick="unblockUser('@Model.Id')" class="btn-sm-red w-100 justify-content-center">
                            <i class="fas fa-unlock"></i> Unblock User
                        </button>
                    }
                    else
                    {
                        <span class="status-pill sp-completed">Active</span>
                        <button onclick="blockUser('@Model.Id')" class="btn-sm-outline w-100 justify-content-center" style="color:#EF4444;border-color:#FECACA;">
                            <i class="fas fa-ban"></i> Block User
                        </button>
                    }

                    @if (Model.DonorInfo != null && !Model.IsVerified)
                    {
                        <button onclick="verifyDonor(@Model.DonorInfo.DonorProfileId)" class="btn-sm-outline w-100 justify-content-center" style="color:var(--success-green);border-color:#6EE7B7;">
                            <i class="fas fa-check-circle"></i> Verify Donor
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <span>Personal Information</span>
            </div>
            <div class="admin-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="info-card">
                            <div style="font-size:0.72rem;font-weight:600;color:var(--text-muted);">PHONE</div>
                            <div style="font-size:0.95rem;font-weight:700;color:var(--navy-blue);margin-top:0.25rem;">
                                @(Model.PhoneNumber ?? "Not set")
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-card">
                            <div style="font-size:0.72rem;font-weight:600;color:var(--text-muted);">AGE / GENDER</div>
                            <div style="font-size:0.95rem;font-weight:700;color:var(--navy-blue);margin-top:0.25rem;">
                                @Model.Age years · @Model.Gender
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-card">
                            <div style="font-size:0.72rem;font-weight:600;color:var(--text-muted);">LOCATION</div>
                            <div style="font-size:0.95rem;font-weight:700;color:var(--navy-blue);margin-top:0.25rem;">
                                @Model.Upazila, @Model.District
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-card">
                            <div style="font-size:0.72rem;font-weight:600;color:var(--text-muted);">JOINED</div>
                            <div style="font-size:0.95rem;font-weight:700;color:var(--navy-blue);margin-top:0.25rem;">
                                @Model.CreatedAt.ToString("dd MMMM yyyy")
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.DonorInfo != null)
                {
                    <hr style="border-color:var(--card-border);margin:1.5rem 0;" />
                    <div style="font-size:0.9rem;font-weight:700;color:var(--navy-blue);margin-bottom:1rem;">
                        🩸 Donor Information
                    </div>
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div class="stat-card">
                                <div class="stat-number">@Model.DonorInfo.TotalDonations</div>
                                <div class="stat-label">Donations</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="stat-card">
                                <div class="stat-number">@Model.DonorInfo.AverageRating.ToString("0.0")</div>
                                <div class="stat-label">Rating</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="stat-card">
                                <div class="stat-number">@Model.DonorInfo.LivesSaved</div>
                                <div class="stat-label">Lives Saved</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="stat-card">
                                <div class="stat-number">@Model.DonorInfo.TotalPoints</div>
                                <div class="stat-label">Points</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function blockUser(userId) {
            if (!confirm('Block this user?')) return;
            const res = await fetch(`/AdminUser/Block/${userId}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() }
            });
            const data = await res.json();
            if (data.success) { showToast('User blocked.', 'success'); location.reload(); }
            else showToast(data.message, 'error');
        }

        async function unblockUser(userId) {
            if (!confirm('Unblock this user?')) return;
            const res = await fetch(`/AdminUser/Unblock/${userId}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() }
            });
            const data = await res.json();
            if (data.success) { showToast('User unblocked.', 'success'); location.reload(); }
            else showToast(data.message, 'error');
        }

        async function verifyDonor(donorProfileId) {
            if (!confirm('Verify this donor?')) return;
            const res = await fetch(`/AdminUser/VerifyDonor/${donorProfileId}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() }
            });
            const data = await res.json();
            if (data.success) { showToast('Donor verified!', 'success'); location.reload(); }
            else showToast(data.message, 'error');
        }
    </script>
}