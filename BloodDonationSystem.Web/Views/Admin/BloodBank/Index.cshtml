@using BloodDonationSystem.Application.DTOs.BloodBank
@model List<BloodBankDto>
@{
    ViewData["Title"] = "Manage Blood Banks";
    Layout = "~/Views/Shared/_Layout.Admin.cshtml";
}

<div class="admin-page-header">
    <div class="admin-page-title">🩸 Manage Blood Banks</div>
    <div class="admin-page-sub">Update blood stock levels</div>
</div>

@{
    var lowStocks = ViewBag.LowStocks as List<BloodStockDto> ?? new();
}
@if (lowStocks.Any())
{
    <div class="admin-card mb-3" style="border-color:#FECACA;">
        <div class="admin-card-body" style="background:#FEF2F2;">
            <span style="color:var(--deep-red);font-weight:700;">
                <i class="fas fa-exclamation-triangle"></i>
                @lowStocks.Count blood group(s) running low across all banks
            </span>
        </div>
    </div>
}

<div class="row g-3">
    @foreach (var bank in Model)
    {
        <div class="col-md-6">
            <div class="admin-card">
                <div class="admin-card-header">
                    <span>@bank.Name</span>
                    <a asp-action="Edit" asp-route-id="@bank.Id" class="btn-sm-outline">
                        <i class="fas fa-edit"></i> Manage
                    </a>
                </div>
                <div class="admin-card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var stock in bank.Stocks)
                        {
                            <div style="background:@(stock.IsLow ? "#FEF2F2" : "var(--light-gray)");
                                                border-radius:8px;padding:0.4rem 0.7rem;
                                                text-align:center;min-width:55px;">
                                <div style="font-size:0.8rem;font-weight:800;
                                                    color:@(stock.IsLow ? "var(--deep-red)" : "var(--navy-blue)");">
                                    @stock.BloodGroupDisplay
                                </div>
                                <div style="font-size:0.7rem;color:var(--text-muted);">
                                    @stock.UnitsAvailable
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>